@{
    ViewData["Title"] = "Dashboard";
}

<h1>Security Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                System Status
            </div>
            <div class="card-body">
                <h5 class="card-title">Active Devices: @ViewBag.ActiveDevices</h5>
                <p class="card-text">
                    Total Requests: @ViewBag.SystemStatus.TotalRequests<br>
                    Threat Level: @ViewBag.SystemStatus.AverageThreatLevel.ToString("F2")<br>
                    Last Updated: @DateTime.Now.ToString("HH:mm:ss")
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                Recent Anomalies
            </div>
            <div class="card-body">
                @if (ViewBag.Anomalies != null && ViewBag.Anomalies.Count > 0)
                {
                    <ul class="list-group">
                        @foreach (var anomaly in ViewBag.Anomalies.Take(5))
                        {
                            <li class="list-group-item">
                                <strong>@anomaly.EventType</strong> - @anomaly.IPAddress
                                <br><small>@anomaly.Timestamp.ToString("g")</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p>No recent anomalies detected.</p>
                }
            </div>
        </div>
    </div>
</div>