@model Dictionary<string, object>
@{
    ViewData["Title"] = "Threat Analysis";
}

<h1>Threat Analysis</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                System Metrics
            </div>
            <div class="card-body">
                <p><strong>Total Requests:</strong> @Model["TotalRequests"]</p>
                <p><strong>Average Threat Level:</strong> @Model["AverageThreatLevel"]</p>
                <p><strong>High Risk Requests:</strong> @Model["HighRiskRequests"]</p>
                <p><strong>Unique IPs:</strong> @Model["UniqueIPs"]</p>
                <p><strong>Unique Devices:</strong> @Model["UniqueDevices"]</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                Top Threat Sources
            </div>
            <div class="card-body">
                @if (Model.ContainsKey("TopThreatIPs") && Model["TopThreatIPs"] is Dictionary<string, int> topThreats && topThreats.Any())
                {
                    <ul>
                        @foreach (var ip in topThreats)
                        {
                            <li>@ip.Key: @ip.Value threats</li>
                        }
                    </ul>
                }
                else
                {
                    <p>No high-threat sources detected.</p>
                }
            </div>
        </div>
    </div>
</div>